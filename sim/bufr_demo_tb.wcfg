<?xml version="1.0" encoding="UTF-8"?>
<wave_config>
   <wave_state>
   </wave_state>
   <db_ref_list>
      <db_ref path="bufr_demo_tb_sim.wdb" id="1">
         <top_modules>
            <top_module name="bufr_demo_tb" />
         </top_modules>
      </db_ref>
   </db_ref_list>
   <zoom_setting>
      <ZoomStartTime time="0.000 ns"></ZoomStartTime>
      <ZoomEndTime time="2500.001 ns"></ZoomEndTime>
      <Coverage>1</Coverage>
   </zoom_setting>
   <cursor_setting>
      <Cursor time="0.000 ns"></Cursor>
   </cursor_setting>
   <wvobject type="divider" fp_name="divider">
      <obj_property name="label">Clock &amp; Reset</obj_property>
      <obj_property name="DisplayName">label</obj_property>
   </wvobject>
